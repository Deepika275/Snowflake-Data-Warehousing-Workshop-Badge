-- Create the specific file format requested for the challenge
CREATE OR REPLACE FILE FORMAT garden_plants.veggies.soil_type_table
    TYPE = 'CSV'
    FIELD_DELIMITER = '\t'                 -- Instructs Snowflake that columns are separated by tabs (.tsv)
    SKIP_HEADER = 1                        -- Bypasses the initial descriptive title/header row
    FIELD_OPTIONALLY_ENCLOSED_BY = '"'      -- Keeps text phrases containing internal punctuation unified
    ERROR_ON_COLUMN_COUNT_MISMATCH = FALSE -- Safeguards against rows with extra unescaped commas throwing errors
;

-- Select and format the un-isolated data into discrete columns
SELECT 
    $1 AS SOIL_TYPE_ID, 
    $2 AS SOIL_TYPE, 
    $3 AS SOIL_DESCRIPTION
FROM @util_db.public.my_internal_stage/LU_SOIL_TYPE.tsv
(FILE_FORMAT => garden_plants.veggies.soil_type_table);


