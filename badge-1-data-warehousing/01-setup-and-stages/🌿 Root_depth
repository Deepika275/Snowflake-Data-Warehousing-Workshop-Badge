-- BY MISTAKE I RAN THE ABOVE INSERT STATEMENT TWO TIMES SO 2 ROWS HAVE BEEN INSERTED
-- TO DELETE ONE ROW BELOW IS THE CODE TO RUN AND AFTER RUNNNIG BELOW CODE ONE ROW        REMAINS.

   DELETE FROM root_depth
   USING (
    SELECT root_depth_id, root_depth_code, root_depth_name, unit_of_measure,               range_min, range_max,
           ROW_NUMBER() OVER (
                PARTITION BY root_depth_id, root_depth_code, root_depth_name,               unit_of_measure, range_min, range_max
                ORDER BY root_depth_id
           ) AS rn
    FROM root_depth
   ) AS dupes
  WHERE root_depth.root_depth_id = dupes.root_depth_id
  AND root_depth.root_depth_code = dupes.root_depth_code
  AND root_depth.root_depth_name = dupes.root_depth_name
  AND root_depth.unit_of_measure = dupes.unit_of_measure
  AND root_depth.range_min = dupes.range_min
  AND root_depth.range_max = dupes.range_max
  AND dupes.rn > 1;


